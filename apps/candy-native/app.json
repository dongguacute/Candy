{
  "expo": {
    "name": "Candy",
    "slug": "candy-native",
    "version": "0.0.0",
    "scheme": "candy",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#FCD34D"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dongguacute.candy"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FCD34D"
      },
      "package": "com.dongguacute.candy"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "backgroundColor": "#FCD34D",
          "imageWidth": 200
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#FCD34D"
        }
      ]
    ]
  }
}
