{
  "name": "candy-monorepo",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "overrides": {
      "@types/react": "18.3.12",
      "@types/react-dom": "18.3.1"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "sharp",
      "unrs-resolver"
    ]
  },
  "scripts": {
    "native:start": "pnpm --filter candy-native run start",
    "native:android": "pnpm --filter candy-native run android",
    "native:ios": "pnpm --filter candy-native run ios",
    "native:typecheck": "pnpm --filter candy-native exec tsc --noEmit"
  }
}
